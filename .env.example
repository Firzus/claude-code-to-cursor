# Port to run the proxy on (default: 8082)
# PORT=8082

# IP whitelist for requests coming through the Cloudflare tunnel (comma-separated)
# Default: Cursor backend IPs. Set to "disabled" to allow all IPs.
# ALLOWED_IPS=52.44.113.131,184.73.225.134

# --- Docker-specific settings ---

# Auth token storage directory (Docker: /data/auth, local: ~/.cctc)
# CCTC_AUTH_DIR=/data/auth

# Log files directory (Docker: /data/logs, local: current directory)
# LOG_DIR=/data/logs

# Log level: VERBOSE | DEBUG | INFO | WARN | ERROR (default: INFO)
# LOG_LEVEL=INFO

# Max log file size in MB before rotation (default: 10)
# LOG_MAX_SIZE_MB=10

# Number of rotated log files to keep (default: 3)
# LOG_MAX_FILES=3

# Write logs to stdout/stderr too (default: true, set "false" to disable)
# LOG_CONSOLE=true

# SQLite database path
# CCTC_DB_PATH=/data/cctc.db

# Shared secret for settings API access from frontend (empty = unrestricted)
# SETTINGS_API_KEY=

# Frontend port (default: 3111)
# FRONTEND_PORT=3111

# Cloudflare tunnel token (REQUIRED — the tunnel is mandatory for claude-code-to-cursor to work)
# CLOUDFLARE_TUNNEL_TOKEN=

# Public URL of the Cloudflare tunnel (shown in setup wizard for client configuration)
# CLOUDFLARE_TUNNEL_URL=https://ccproxy.lprieu.dev
