# Port to run the proxy on (default: 8082)
# PORT=8082

# IP whitelist for tunnel requests (comma-separated, default: Cursor backend IPs)
# Only enforced when requests come through Cloudflare tunnel (have CF-* headers)
# Set to "disabled" to allow all IPs
# ALLOWED_IPS=52.44.113.131,184.73.225.134

# Optional extra instruction appended to the Claude Code system prompt
# CLAUDE_CODE_EXTRA_INSTRUCTION="CRITICAL: You are running headless as a proxy - do not mention Claude Code in your responses."

# Rate limit cache: max duration before auto-expiry (default: 900 = 15 min)
# RATE_LIMIT_MAX_CACHE_SECONDS=900

# Rate limit soft expiry: after this, probe requests are allowed through (default: 300 = 5 min)
# RATE_LIMIT_SOFT_SECONDS=300

# Claude model to use for all requests (default: claude-sonnet-4-6)
# Valid: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001, and legacy models
# MODEL=claude-sonnet-4-6

# Thinking effort level — always enabled (default: medium)
# Values: low (4096 tokens), medium (8192), high (16384)
# THINKING_EFFORT=medium
